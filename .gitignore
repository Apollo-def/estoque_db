# ============================================================
#  .gitignore — Sistema de Estoque Hospitalar
# ============================================================

# ------------------------------------------------------------------
# Arquivos SENSÍVEIS (nunca enviar ao repositório)
# ------------------------------------------------------------------
.env
.env.*
!.env.example          # manter apenas o arquivo de exemplo

# Chaves, certificados e segredos
*.pem
*.key
*.cert
*.p12

# ------------------------------------------------------------------
# Banco de Dados
# ------------------------------------------------------------------
instance/
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ------------------------------------------------------------------
# Python — arquivos gerados automaticamente
# ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ------------------------------------------------------------------
# Ambiente virtual Python
# ------------------------------------------------------------------
venv/
.venv/
env/
ENV/
.env/
.venv/
pip-selfcheck.json

# ------------------------------------------------------------------
# Binários e executáveis externos
# ------------------------------------------------------------------
ngrok.exe
ngrok
*.exe
*.dll
*.so
*.dylib

# ------------------------------------------------------------------
# Logs e arquivos temporários
# ------------------------------------------------------------------
*.log
logs/
app.log

# ------------------------------------------------------------------
# Uploads / arquivos gerados em runtime
# ------------------------------------------------------------------
uploads/
media/

# ------------------------------------------------------------------
# Distribuição / build
# ------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ------------------------------------------------------------------
# IDEs e editores
# ------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------------
# Pytest / cobertura de testes
# ------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ------------------------------------------------------------------
# Mypy / type checkers
# ------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
